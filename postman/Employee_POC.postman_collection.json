{
  "info": {
    "name": "Employee POC API",
    "description": "CRUD endpoints for the Employee POC (Spring Boot + H2). Base URL and employeeId are collection variables. Running 'Create Employee' saves the returned id into {{employeeId}}, so Get/Update/Delete work immediately after.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "employeeId",
      "value": "1",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "List all employees",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/employees",
          "host": ["{{baseUrl}}"],
          "path": ["api", "employees"]
        },
        "description": "GET /api/employees -> 200 with an array of all employees."
      },
      "response": []
    },
    {
      "name": "Get employee by id",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/employees/{{employeeId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "employees", "{{employeeId}}"]
        },
        "description": "GET /api/employees/{id} -> 200, or 404 if the id does not exist."
      },
      "response": []
    },
    {
      "name": "Create employee",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 201 Created', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "var body = pm.response.json();",
              "if (body && body.id != null) {",
              "    pm.collectionVariables.set('employeeId', body.id);",
              "    console.log('Saved employeeId =', body.id);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"Ada\",\n  \"lastName\": \"Lovelace\",\n  \"email\": \"ada@example.com\",\n  \"department\": \"Engineering\",\n  \"designation\": \"Senior Engineer\",\n  \"salary\": 120000\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/employees",
          "host": ["{{baseUrl}}"],
          "path": ["api", "employees"]
        },
        "description": "POST /api/employees -> 201 Created with the saved employee (including its generated id). The test script stores that id into {{employeeId}}."
      },
      "response": []
    },
    {
      "name": "Update employee",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"Ada\",\n  \"lastName\": \"Lovelace\",\n  \"email\": \"ada@example.com\",\n  \"department\": \"Engineering\",\n  \"designation\": \"Principal Engineer\",\n  \"salary\": 150000\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/employees/{{employeeId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "employees", "{{employeeId}}"]
        },
        "description": "PUT /api/employees/{id} -> 200 with the updated employee, or 404 if the id does not exist."
      },
      "response": []
    },
    {
      "name": "Delete employee",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/employees/{{employeeId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "employees", "{{employeeId}}"]
        },
        "description": "DELETE /api/employees/{id} -> 204 No Content, or 404 if the id does not exist."
      },
      "response": []
    }
  ]
}
