{
  "info": {
    "name": "Employee POC API (JWT)",
    "description": "All endpoints for the Employee POC (Spring Boot + JWT). Two folders: Auth (register/login) and Employees (protected CRUD).\n\nHow to use:\n1. Run Auth > Login (default admin/admin123) or Auth > Register. The test script saves the returned JWT into the {{token}} collection variable.\n2. All Employees requests inherit collection-level Bearer auth using {{token}}, so they are authorized automatically.\n3. Employees > Create saves the new id into {{employeeId}}, so Get/Update/Delete target it.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{token}}", "type": "string" }
    ]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "employeeId", "value": "1", "type": "string" },
    { "key": "authUsername", "value": "admin", "type": "string" },
    { "key": "authPassword", "value": "admin123", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201 Created', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "var body = pm.response.json();",
                  "if (body && body.token) {",
                  "    pm.collectionVariables.set('token', body.token);",
                  "    console.log('Saved token from register');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"newuser\",\n  \"password\": \"secret123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "POST /api/auth/register -> 201 with { token, username }. Returns 409 if the username is taken, 400 if fields are blank."
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "var body = pm.response.json();",
                  "if (body && body.token) {",
                  "    pm.collectionVariables.set('token', body.token);",
                  "    console.log('Saved token from login');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{authUsername}}\",\n  \"password\": \"{{authPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "POST /api/auth/login -> 200 with { token, username }. Uses the seeded admin by default. Returns 401 on wrong credentials."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Employees",
      "description": "Protected CRUD. Requires a valid token (run Auth > Login first).",
      "item": [
        {
          "name": "List all employees",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/employees",
              "host": ["{{baseUrl}}"],
              "path": ["api", "employees"]
            },
            "description": "GET /api/employees -> 200 array (401 if no/expired token)."
          },
          "response": []
        },
        {
          "name": "Get employee by id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/employees/{{employeeId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "employees", "{{employeeId}}"]
            },
            "description": "GET /api/employees/{id} -> 200, or 404 if not found."
          },
          "response": []
        },
        {
          "name": "Create employee",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201 Created', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "var body = pm.response.json();",
                  "if (body && body.id != null) {",
                  "    pm.collectionVariables.set('employeeId', body.id);",
                  "    console.log('Saved employeeId =', body.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Ada\",\n  \"lastName\": \"Lovelace\",\n  \"email\": \"ada@example.com\",\n  \"department\": \"Engineering\",\n  \"designation\": \"Senior Engineer\",\n  \"salary\": 120000\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/employees",
              "host": ["{{baseUrl}}"],
              "path": ["api", "employees"]
            },
            "description": "POST /api/employees -> 201 with the saved employee. The test script stores its id into {{employeeId}}. Returns 400 on validation errors."
          },
          "response": []
        },
        {
          "name": "Update employee",
          "request": {
            "method": "PUT",
            "header": [ { "key": "Content-Type", "value": "application/json" } ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Ada\",\n  \"lastName\": \"Lovelace\",\n  \"email\": \"ada@example.com\",\n  \"department\": \"Engineering\",\n  \"designation\": \"Principal Engineer\",\n  \"salary\": 150000\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/employees/{{employeeId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "employees", "{{employeeId}}"]
            },
            "description": "PUT /api/employees/{id} -> 200 with the updated employee, or 404 if not found."
          },
          "response": []
        },
        {
          "name": "Delete employee",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/employees/{{employeeId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "employees", "{{employeeId}}"]
            },
            "description": "DELETE /api/employees/{id} -> 204 No Content, or 404 if not found."
          },
          "response": []
        }
      ]
    }
  ]
}
